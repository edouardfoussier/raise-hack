# ---------------------------------------------------------------------------
# Scenario web — environment variables
#
# The app runs with NO variables set: it defaults to DEMO MODE, which provides a
# deterministic signed-in "Demo User" and lets the dashboard render without a
# real auth provider. Copy this file to `.env.local` only if you want real auth.
# ---------------------------------------------------------------------------

# Demo mode toggle.
#   1     -> force demo mode ON  (deterministic mock user, no Clerk required)
#   0     -> force demo mode OFF (requires the Clerk keys below)
#   unset -> ON automatically whenever the Clerk publishable key is missing
NEXT_PUBLIC_DEMO_MODE=1

# Clerk (https://dashboard.clerk.com) — only needed when NEXT_PUBLIC_DEMO_MODE=0.
# Enable the GitHub OAuth provider in the Clerk dashboard for "Sign in with GitHub".
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional Clerk route overrides (defaults shown).
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ---------------------------------------------------------------------------
# Scenario web — environment variables
#
# The app runs with NO variables set: it defaults to DEMO MODE, which provides a
# deterministic signed-in "Demo User" and lets the dashboard render without a
# real auth provider. Copy this file to `.env.local` only if you want real auth.
# ---------------------------------------------------------------------------

# Demo mode toggle.
#   1     -> force demo mode ON  (deterministic mock user, no Clerk required)
#   0     -> force demo mode OFF (requires the Clerk keys below)
#   unset -> ON automatically whenever the Clerk publishable key is missing
NEXT_PUBLIC_DEMO_MODE=1

# Clerk (https://dashboard.clerk.com) — only needed when NEXT_PUBLIC_DEMO_MODE=0.
# Enable the GitHub OAuth provider in the Clerk dashboard for "Sign in with GitHub".
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional Clerk route overrides (defaults shown).
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ---------------------------------------------------------------------------
# Live "Generate demo" flow — POST /api/generate spawns the Scenario engine
# (mcp-server/src/cli-demo.ts) to produce a captioned, voiced demo video.
# These are read server-side only; copy this file to `.env.local` and fill them.
# NEVER commit `.env.local` (it is gitignored).
# ---------------------------------------------------------------------------

# deja-bu protected Vercel preview (the live demo target). When the Generate
# form's URL host matches DEJA_URL, the route injects the Vercel
# protection-bypass header + a localStorage auth-token seed so the engine reaches
# the real app instead of the SSO / password wall.
DEJA_URL=
DEJA_BYPASS=
DEJA_PWD=

# Voice-over: Edouard's cloned Gradium voice id. The GRADIUM_API_KEY itself lives
# in mcp-server/.env (loaded by the engine), not here.
GRADIUM_VOICE_ID=

# Optional: brand word shown on the intro card (default "Scenario").
# DEMO_TITLE=Scenario

# Optional: absolute repo root, only if the web app is NOT run from <repo>/web.
# SCENARIO_REPO_ROOT=

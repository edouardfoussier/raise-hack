# Drift VLM configuration (hosted-first; swap to Nemotron VL on DGX later for the NVIDIA bonus).
# Recommended: OpenRouter (uses the hackathon bonus credits, one key for Claude/Gemini/etc.)
OPENROUTER_API_KEY=

# Vision model id used for the verdict. Override to taste.
DRIFT_VLM_MODEL=anthropic/claude-sonnet-5

# --- Alternatives (use instead of OpenRouter) ---
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
